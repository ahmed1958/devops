pipeline {
    agent any 
    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/ahmed1958/devops'
            }
        }
        stage('Deploy the App') {
            steps {
                script {
                    // Navigate to app_deployment directory and run Ansible Playbook
                      sh 'kubectl apply -k k8s'
                    }
                }
            }
        }
    }
