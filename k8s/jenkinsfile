pipeline {
    agent any 
    stages {
        stage('Clone Repository') {
            steps {
                git branch: 'main', url: 'https://github.com/ahmed1958/devops'
            }
        }
        stage('Deploy the App') {
            steps {
                script {
                    // Navigate to app_deployment directory and run Ansible Playbook
                      sh 'cd k8s && kubectl apply -f vote.yml'
                      sh 'cd k8s && kubectl apply -f redis.yml'
                      sh 'cd k8s && kubectl apply -f db.yml'
                      sh 'cd k8s && kubectl apply -f worker.yml'
                      sh 'cd k8s && kubectl apply -f result.yml'
                      
                    }
                }
            }
        }
    }
